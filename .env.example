# Copy to .env for local development (never commit .env)

DEBUG=True
SECRET_KEY=change-me-for-local-only

# Database (local PostgreSQL)
DB_NAME=delivery_app
DB_USER=delivery_user
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Bootstrap admin (required for: python manage.py ensure_admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=

# CORS (comma-separated origins for production)
# CORS_ORIGINS=https://deliveryapp-mobile.vercel.app
